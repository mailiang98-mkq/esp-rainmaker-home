# APP IDENTITY & BRANDING
APP_NAME=ESP RainMaker Home
IOS_APP_APPLICATION_ID=com.espressif.nova
ANDROID_APP_APPLICATION_ID=com.espressif.novahome
IOS_APP_GROUP_ID=group.com.espressif.novahome
APP_SLUG=esp-rainmaker-home
APP_SCHEMA=rainmaker

# VERSION INFORMATION
APP_VERSION=4.0.1
ANDROID_VERSION_CODE=38

# SCAN CONFIGURATION
ENABLE_SCAN_CONFIGURATION=true

# RM SDK CONFIGURATION
BASE_URL=https://api.rainmaker.espressif.com
API_VERSION=v1


# RMNG SDK CONFIGURATION
RMNG_BASE_URL=https://c2vxptrsrk.execute-api.ap-south-1.amazonaws.com
RMNG_API_PATH=/prod
RMNG_USER_API_BASE_URL=https://hahrmpl4kj.execute-api.ap-south-1.amazonaws.com
RMNG_USER_API_PATH=/prod
RMNG_IDENTITY_ID=ap-south-1:97779d56-d730-439c-bec0-688a32ea0f76
RMNG_AWS_REGION=ap-south-1
RMNG_USER_POOL_ID=ap-south-1_bB5ywfmj3
RMNG_CLIENT_ID=5vask3aug0ahtbdc7rnqbdvvi7
RMNG_IOT_ENDPOINT=a8q3zcvoujce1-ats.iot.ap-south-1.amazonaws.com

# ACTIVE SDK (rainmaker-base-sdk | rmng-base-sdk | rainmaker-matter-sdk)
ACTIVE_SDK=rainmaker-matter-sdk

# FEATURE FLAGS & OPTIONS
ENABLE_CDF_AUTOSYNC=true

# FEATURE FLAGS (Level 1) — set to false to disable a module
# RMNG-unsupported: auto-disabled by SDK map when ACTIVE_SDK=rmng-base-sdk
ENABLE_SCENES=true
ENABLE_SCHEDULES=true
ENABLE_LOCAL_CONTROL=true
ENABLE_NOTIFICATIONS=true
ENABLE_GROUP_SHARING=true
ENABLE_OTA=true
# Both SDKs supported — env-only control
ENABLE_AUTOMATIONS=true
ENABLE_AI_AGENT=true
# Third-party auth (replaces legacy ENABLE_THIRD_PARTY_AUTH pattern)
ENABLE_THIRD_PARTY_AUTH=true
THIRD_PARTY_AUTH_ENABLED_PROVIDERS=Google,SignInWithApple
# Voice assistants
ENABLE_VOICE_ASSISTANTS=true
# Device control groups (Level 1). Hard-disabled when ACTIVE_SDK is not rmng-base-sdk.
ENABLE_CONTROL_GROUPS=true

# THIRD PARTY AUTH CONFIGURATION
THIRD_PARTY_AUTH_REDIRECT_SCHEME=rainmaker
THIRD_PARTY_AUTH_REDIRECT_HOST=com.espressif.novahome
THIRD_PARTY_AUTH_CLIENT_ID=1h7ujqjs8140n17v0ahb4n51m2
THIRD_PARTY_AUTH_AUTH_URL=https://3pauth.rainmaker.espressif.com
THIRD_PARTY_AUTH_REDIRECT_URL=rainmaker://com.espressif.novahome/success
THIRD_PARTY_AUTH_ENABLED_THIRD_PARTY_PROVIDERS=Google,SignInWithApple

# DEEP LINK & URL SCHEMES
AGENTS_DEEP_LINK_SCHEME=rainmaker
AGENTS_DEEP_LINK_HOST=agents.espressif.com
AGENTS_DEEP_LINK_PATH_PREFIX=/try/agents

# MATTER CONFIGURATION
MATTER_VENDOR_ID=0x131B
MATTER_ECOSYSTEM_NAME=Rainmaker Home

# PUBLIC WEBSITE & LEGAL (CLI / white-label; baked into app via app.config.ts extra)
WEBSITE_LINK=https://rainmaker.espressif.com
TERMS_OF_USE_LINK=https://rainmaker.espressif.com/docs/terms-of-use.html
PRIVACY_POLICY_LINK=https://rainmaker.espressif.com/docs/privacy-policy.html