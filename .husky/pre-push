branch=$(git symbolic-ref --short HEAD 2>/dev/null)

pattern="^(task|feature|bugfix|hotfix|enhancement|release)/[a-z0-9-]+$"

if ! echo "$branch" | grep -qE "$pattern"; then
  echo ""
  echo "❌ Invalid branch name: \"$branch\""
  echo ""
  echo "   Allowed prefixes:"
  echo "     task/<name>"
  echo "     feature/<name>"
  echo "     bugfix/<name>"
  echo "     hotfix/<name>"
  echo "     enhancement/<name>"
  echo "     release/<name>"
  echo ""
  echo "   Rules for <name>: lowercase letters, numbers, and '-' only"
  echo ""
  exit 1
fi
