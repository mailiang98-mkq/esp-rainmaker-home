{
  "name": "NOVA",
  "main": "expo-router/entry",
  "version": "4.2.0",
  "scripts": {
    "start": "expo start",
    "start:dev": "APP_ENV=development expo start -c",
    "start:staging": "APP_ENV=staging expo start -c",
    "start:prod": "APP_ENV=production expo start -c",
    "prebuild": "npm run prebuild:android && npm run prebuild:ios",
    "prebuild:android": "node scripts/sync-env-to-android.js",
    "prebuild:ios": "node scripts/sync-env-to-ios.js",
    "android": "npm run prebuild:android && expo run:android",
    "ios": "npm run prebuild:ios && expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "lint:arch": "depcruise src config app --config .dependency-cruiser.cjs --validate --output-type err",
    "typecheck": "tsc --noEmit",
    "check:arch": "npm run lint:arch",
    "spell": "cspell lint --no-progress",
    "check": "npm run typecheck && npm run spell && npm run lint:arch && npm run lint",
    "prepare": "husky"
  },
