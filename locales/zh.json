{
  "alexa": {
    "guide": "Alexa 指南",
    "step1": "1. 在菜单中点击 \"Skills & Games\"，然后搜索 \"ESP RainMaker Home\"。",
    "step2": "2. 选择 \"ESP RainMaker Home\" 并点击 \"ENABLE\" 以启用该技能。",
    "step3": "3. 您将被重定向到账户绑定页面。输入 ESP RainMaker Home 账户和密码，然后点击 \"Link Now\" 绑定账户。",
    "step4": "4. 账户绑定成功后，允许 Alexa 发现您的设备。设备成功发现后，设置即完成，您可以使用 Alexa 开始控制设备。"
  },
  "googleAssistant": {
    "guide": "Google Assistant 指南",
    "step1": "1. 打开 Google Home 应用，点击 \"Add\" 添加设备，然后选择 \"Set up device\" 设置设备。",
    "step2": "2. 选择 \"Works with Google\"，并搜索 \"ESP RainMaker Home\"。",
    "step3": "3. 使用您的 ESP RainMaker Home 账户登录以绑定账户。",
    "step4": "4. 链接成功后，您的设备将在 Google Assistant 中可用。您现在可以使用语音命令控制它们。"
  },
